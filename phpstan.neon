includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:

    paths:
        - app/

    # Level 9 is the highest level
    level: 0

    scanFiles:
        - _ide_helper.php
        - _ide_helper_models.php

